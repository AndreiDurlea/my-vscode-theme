{
  "name": "deutherium",
  "displayName": "Deutherium",
  "description": "My custom VS Code theme, packaged from Deutherium.",
  "version": "1.0.0",
  "publisher": "andreidurlea",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreiDurlea/my-vscode-theme.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Deutherium",
        "uiTheme": "vs-dark",
        "path": "./themes/deutherium-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "editor.fontFamily": "'JetBrains Mono', 'Fira Code', Consolas, Menlo, Monaco, 'Courier New', monospace",
      "editor.bracketPairColorization.enabled": false
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.19.0"
  }
}
