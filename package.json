{
  "name": "my-vscode-theme",
  "displayName": "Vantablack",
  "description": "My custom VS Code theme, packaged from Vantablack.",
  "version": "1.0.0",
  "publisher": "andreidurlea",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Vantablack",
        "uiTheme": "vs-dark",
        "path": "./themes/vantablack-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "editor.fontFamily": "'JetBrains Mono', monospace",
      "editor.bracketPairColorization.enabled": false
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.19.0"
  }
}
